# ----- Supabase -----
# Public values exposed to client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Server-only — bypasses RLS, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ----- Database (Drizzle / migrations / seed) -----
# Use the Supabase connection-pooler URL for runtime, direct URL for migrations
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ----- AI providers -----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development

# ----- Agent memory bridge (.claude/hooks/* → /agent/*) -----
# All three required to enable /agent/bootstrap and /agent/sessions/:id/checkpoint.
# If any are missing the routes return 503 and the hooks log to stderr.
# The configured user must be a member of the configured org with at least
# `member` role. Generate the token with: openssl rand -hex 32
MEMORY_AGENT_TOKEN=
MEMORY_AGENT_ORG_ID=
MEMORY_AGENT_USER_ID=

# ----- Seed -----
SEED_NOTE_COUNT=10000
SEED_USER_COUNT=20
SEED_ORG_COUNT=5
